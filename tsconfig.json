{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Svelte 5 */
    "jsx": "preserve",
    "allowJs": true,
    "checkJs": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,

    /* Override @tsconfig/svelte verbatimModuleSyntax to reduce TS1484 noise */
    "verbatimModuleSyntax": false,

    /* Path resolution */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],

      /* ── Target architecture (flat) ─────────────────── */
      "@domain/*": ["src/domain/*"],
      "@application/*": ["src/application/*"],
      "@infrastructure/*": ["src/infrastructure/*"],
      "@runtime/*": ["src/runtime/*"],
      "@services/*": ["src/services/*"],
      "@query/*": ["src/query/*"],
      "@cache/*": ["src/cache/*"],
      "@engine/*": ["src/engine/*"],
      "@reminders/*": ["src/reminders/*"],
      "@dependencies/*": ["src/dependencies/*"],
      "@escalation/*": ["src/escalation/*"],
      "@integrations/*": ["src/integrations/*"],
      "@events/*": ["src/events/*"],
      "@parsers/*": ["src/parsers/*"],
      "@models/*": ["src/models/*"],
      "@stores/*": ["src/stores/*"],
      "@mounts/*": ["src/mounts/*"],
      "@components/*": ["src/components/*"],
      "@styles/*": ["src/styles/*"],
      "@utils/*": ["src/utils/*"],

      /* ── Legacy aliases (backward compat during migration) ── */
      "@backend/*": ["src/backend/*"],
      "@frontend/*": ["src/frontend/*"],
      "@shared/*": ["src/shared/*"],
      "@hooks/*": ["src/frontend/hooks/*"],
      "@modals/*": ["src/frontend/modals/*"],
      "@views/*": ["src/frontend/views/*"]
    },

    /* SiYuan plugin compatibility */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.svelte"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
